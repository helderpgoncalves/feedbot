# ─── Database ──────────────────────────────────────────────────────────────
# Inside docker-compose this resolves to the `db` service. For host-based dev
# (uvicorn --reload outside Docker) change `db` → `localhost`.
DATABASE_URL=postgresql+asyncpg://feedbot:feedbot@db:5432/feedbot

# ─── Core API ──────────────────────────────────────────────────────────────
FEEDBOT_BASE_URL=http://localhost:8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
FEEDBOT_SECRET_KEY=change-me-to-a-long-random-string
FEEDBOT_LOG_LEVEL=INFO

# ─── Email (magic-link auth) ───────────────────────────────────────────────
# In dev keep EMAIL_BACKEND=console — magic links are printed to the API logs.
# In production (FEEDBOT_BASE_URL is https://...) the app refuses to send magic
# links over the console backend; users would never receive them. Set
# EMAIL_BACKEND=smtp + the SMTP_* vars below before opening the instance.
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=feedbot@example.com

# ─── LLM (optional, for classification) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Telegram bot ──────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather → /newbot → save the token here.
# 2. /setprivacy → Disable (so the bot can read group messages).
# 3. Set the bot's @username (without leading @) so the dashboard can build
#    the deep-link button "Open Telegram → Add to group".
TELEGRAM_BOT_TOKEN=
FEEDBOT_TELEGRAM_BOT_USERNAME=

# ─── Bot ↔ API shared secret ──────────────────────────────────────────────
# Used by the bot to call /v1/internal/* — server-side only, never exposed to
# users or browsers. Generate with the same command as FEEDBOT_SECRET_KEY.
FEEDBOT_BOT_TOKEN=

# ─── MCP client (set on the developer's machine, not on the server) ────────
# FEEDBOT_API_URL=https://feedbot.example.com
# FEEDBOT_API_KEY=fbk_live_...
