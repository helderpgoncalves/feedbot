# ─── Feedbot — minimal .env ─────────────────────────────────────────
# This is all you need to boot. Everything else (Telegram bot token,
# SMTP credentials, OpenAI API key, branding) is configured AFTER first
# boot via the admin panel at ${FEEDBOT_BASE_URL}/admin/settings.
#
# First boot:
#   1. cp .env.example .env
#   2. Edit FEEDBOT_SECRET_KEY (see the generation command below).
#   3. docker compose up -d
#   4. Open ${FEEDBOT_BASE_URL} — the setup wizard creates the admin
#      account and walks you through the optional services.
# ────────────────────────────────────────────────────────────────────

# Public URL where users will reach this instance. Used for magic-link
# emails and webhooks. Set to https:// in production.
FEEDBOT_BASE_URL=http://localhost:8000

# 48-byte secret used to sign sessions and API tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FEEDBOT_SECRET_KEY=change-me-to-a-long-random-string

# Postgres connection. The default works with the bundled `db` service
# in docker-compose.yml. Change only when pointing at an external DB.
DATABASE_URL=postgresql+asyncpg://feedbot:feedbot@db:5432/feedbot

# ─── Optional overrides ─────────────────────────────────────────────
# Everything below can be configured in the admin panel. Set values
# here only when an orchestrator (Kubernetes secrets, Coolify, etc.)
# already manages credentials externally — env vars take precedence
# over panel-saved values at every boot.
#
# FEEDBOT_LOG_LEVEL=INFO
# FEEDBOT_BIND_HOST=127.0.0.1            # 0.0.0.0 to expose on LAN
# FEEDBOT_HTTP_PORT=80
# FEEDBOT_HTTPS_PORT=443
#
# Telegram bot — self-host runs YOUR bot. Cloud users connect to the
# operator's @FeedbotBot and don't need this.
# TELEGRAM_BOT_TOKEN=
# FEEDBOT_TELEGRAM_BOT_USERNAME=
#
# SMTP for magic-link delivery — required in production (HTTPS refuses
# the console backend). Self-host: configure in the panel. Cloud: the
# operator provides the shared SMTP.
# EMAIL_BACKEND=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
#
# LLM classification keys are NOT set here. They're per-project, BYOK,
# configured at /projects/<slug>/llm in the dashboard and stored
# encrypted in `project_llm_settings`. Self-host operators don't need
# any LLM env var — projects can use OpenAI, Anthropic, or none.
#
# ─── Web app (runtime config injected by the entrypoint) ────────────
# Branding and feature flags. These are baked into /config.json on
# every container start; `docker compose restart web` to apply.
# FEEDBOT_PRODUCT_NAME=Feedbot
# FEEDBOT_PUBLIC_URL=                    # defaults to FEEDBOT_BASE_URL
# FEEDBOT_MCP_PUBLIC_URL=                # only for split-domain deploys
# FEEDBOT_ALLOW_SIGNUP=false             # cloud only
# FEEDBOT_BILLING_ENABLED=false          # cloud commercial only
# FEEDBOT_DEPLOYMENT=self-host           # `cloud` shows plan/billing UI
# FEEDBOT_BUILD_SHA=                     # commit shown in footer
#
# ─── MCP client (for the developer's machine, not the server) ──────
# FEEDBOT_API_URL=https://feedbot.example.com
# FEEDBOT_API_KEY=fbk_live_...
