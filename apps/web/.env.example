# Where the Vite dev server proxies /api/* during local development.
# In production this is configured via the Caddy env (FEEDBOT_API_UPSTREAM).
VITE_API_PROXY=http://localhost:8000

# Optional: bake commit SHA into the build for footer traceability.
# Coolify exposes $SOURCE_COMMIT; you can pass it via Docker build args.
# VITE_BUILD_SHA=
