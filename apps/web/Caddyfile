# ──────────────────────────────────────────────────────────────────────────────
# Feedbot web — Caddy serves the static SPA and proxies the API at /api/*.
# Runtime config (`/config.json`) is templated from env vars on each request,
# so self-hosters change `docker-compose.yml` and `restart` — never rebuild.
# ──────────────────────────────────────────────────────────────────────────────

{
	# Coolify (and most reverse proxies) terminate TLS upstream; tell Caddy
	# to trust X-Forwarded-* headers and disable its own TLS handling.
	auto_https off
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	root * /srv
	encode gzip zstd

	# ── Runtime config: rendered with current env on every request. ───────────
	@config path /config.json
	handle @config {
		header Content-Type "application/json"
		header Cache-Control "no-store"
		templates
		respond `{
			"productName":         "{{ env "FEEDBOT_PRODUCT_NAME" }}",
			"publicUrl":           "{{ env "FEEDBOT_PUBLIC_URL" }}",
			"telegramBotUsername": {{ if env "FEEDBOT_TELEGRAM_BOT_USERNAME" }}"{{ env "FEEDBOT_TELEGRAM_BOT_USERNAME" }}"{{ else }}null{{ end }},
			"allowSignup":         {{ if eq (env "FEEDBOT_ALLOW_SIGNUP") "true" }}true{{ else }}false{{ end }},
			"deployment":          "{{ if env "FEEDBOT_DEPLOYMENT" }}{{ env "FEEDBOT_DEPLOYMENT" }}{{ else }}self-host{{ end }}",
			"buildSha":            {{ if env "FEEDBOT_BUILD_SHA" }}"{{ env "FEEDBOT_BUILD_SHA" }}"{{ else }}null{{ end }}
		}` 200
	}

	# ── API proxy: same-origin so cookies stay tight. ─────────────────────────
	@api path /api/* /mcp/* /login /login/* /setup /setup/*
	handle @api {
		# Strip /api prefix when forwarding so feedbot-api receives /v1/...
		uri strip_prefix /api
		reverse_proxy {$FEEDBOT_API_UPSTREAM:http://api:8000} {
			header_up Host {http.reverse_proxy.upstream.host}
			header_up X-Real-IP {remote}
			header_up X-Forwarded-For {remote}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── Static assets: long-cache fingerprinted bundles, no-cache HTML. ───────
	@hashed path_regexp \.([0-9a-f]{6,})\.(css|js|woff2|svg|png|jpg|jpeg|webp|avif|map)$
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	@html path *.html /
	header @html Cache-Control "no-cache, must-revalidate"

	# ── Security headers. Coolify adds HSTS at the proxy. ─────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=(), camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		# CSP — kept reasonable for shadcn/Radix; tighten further once auth is wired.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}

	# ── SPA fallback: serve index.html for client-side routes. ───────────────
	handle {
		try_files {path} {path}/ /index.html
		file_server
	}
}
