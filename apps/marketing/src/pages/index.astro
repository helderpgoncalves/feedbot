---
// Homepage at https://feedbot.dev/.
//
// Doesn't use the Starlight layout — we want a custom marketing page,
// not docs chrome. Starlight still serves /docs and /<slug> for any
// MDX in src/content/docs/.
import '../styles/landing.css';

const installCmd = 'curl -fsSL https://get.feedbot.dev | sh';
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Feedbot · Turn community chat into a product backlog</title>
        <meta
            name="description"
            content="Open-source feedback collection, MCP-native, self-hostable in 30 seconds. Turn Telegram chat noise into a structured product backlog."
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta property="og:title" content="Feedbot" />
        <meta
            property="og:description"
            content="Turn community chat into a structured product backlog."
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://feedbot.dev/" />
    </head>
    <body class="landing">
        <nav class="landing-nav">
            <a class="brand" href="/">
                <span class="brand-dot"></span>
                feedbot
            </a>
            <div>
                <a href="/introduction/">Docs</a>
                <a href="https://app.feedbot.dev">Try it</a>
                <a href="https://github.com/helderpgoncalves/feedbot">GitHub</a>
            </div>
        </nav>

        <section class="landing-hero">
            <h1>Turn community chat<br />into a product backlog.</h1>
            <p class="tagline">
                Open-source feedback collection that listens to your Telegram
                chats, classifies issues with an LLM, and exposes the
                structured backlog over an MCP server. Self-host in 30
                seconds.
            </p>

            <div class="landing-cta">
                <a class="landing-button primary" href="https://app.feedbot.dev"
                    >Try the cloud →</a
                >
                <a class="landing-button secondary" href="/introduction/"
                    >Read the docs</a
                >
            </div>

            <div class="landing-install">
                <code id="install-cmd">{installCmd}</code>
                <button id="copy-btn" type="button">Copy</button>
            </div>
        </section>

        <section class="landing-features">
            <div class="landing-feature">
                <h3>Self-host in 30 seconds</h3>
                <p>
                    A single <code>curl … | sh</code> bootstraps a Docker
                    stack, generates secrets, and gets you to a running
                    dashboard. No YAML, no <code>.env</code> editing.
                </p>
            </div>
            <div class="landing-feature">
                <h3>Configure in the UI</h3>
                <p>
                    SMTP, Telegram bot, domain, HTTPS — all in the dashboard's
                    Settings page. Save once, the orchestrator rewrites your{' '}
                    <code>.env</code> and restarts only what changed.
                </p>
            </div>
            <div class="landing-feature">
                <h3>MCP-native</h3>
                <p>
                    Every Feedbot install ships an MCP server at{' '}
                    <code>/mcp/</code>. Drop the URL into Claude Code, Cursor,
                    or Windsurf and the model can read and triage feedback.
                </p>
            </div>
            <div class="landing-feature">
                <h3>Telegram-first</h3>
                <p>
                    Add the bot to any group with one deep link. Replies in
                    Telegram are tracked back to the original issue. Optional
                    LLM classifier tags + summarises every message.
                </p>
            </div>
        </section>

        <footer class="landing-footer">
            <a href="/introduction/">Docs</a>
            <a href="https://app.feedbot.dev">Cloud</a>
            <a href="https://github.com/helderpgoncalves/feedbot">GitHub</a>
            <a href="https://github.com/helderpgoncalves/feedbot/blob/main/LICENSE">License</a>
            <p style="margin-top: 1rem;">
                <small>MIT licensed · Made with care</small>
            </p>
        </footer>

        <script>
            const btn = document.getElementById('copy-btn');
            const cmd = document.getElementById('install-cmd');
            btn?.addEventListener('click', async () => {
                if (!cmd?.textContent) return;
                try {
                    await navigator.clipboard.writeText(cmd.textContent);
                    btn.textContent = 'Copied';
                    setTimeout(() => (btn.textContent = 'Copy'), 1500);
                } catch {
                    btn.textContent = 'Press ⌘C';
                }
            });
        </script>
    </body>
</html>
